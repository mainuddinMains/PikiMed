# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (plain postgres:// for local, prisma+postgres:// for Prisma Accelerate)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/pikimed"

# ── Authentication (NextAuth v5) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Full URL of your deployment (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Mapbox ─────────────────────────────────────────────────────────────────────
# Server-side token (not exposed to browser) — used for SSR map fallbacks
MAPBOX_TOKEN="pk.eyJ1Ijoiexample"
# Public token — safe to expose, used in client-side map components
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1Ijoiexample"

# ── App ────────────────────────────────────────────────────────────────────────
# Full public URL used for canonical links and OG metadata
NEXT_PUBLIC_APP_URL="http://localhost:3000"
